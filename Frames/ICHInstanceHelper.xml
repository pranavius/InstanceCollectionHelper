<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
https://raw.githubusercontent.com/Gethe/wow-ui-source/live/Interface/AddOns/Blizzard_SharedXML/UI.xsd">
    <Frame name="ICHInstanceHelper" parent="UIParent" mixin="ICHInstanceHelperMixin" movable="true" frameStrata="HIGH" registerForDrag="LeftButton" hidden="false">
        <Size x="300" y="1"/>
        <Anchors>
            <Anchor point="TOP" y="-50"/>
        </Anchors>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture parentKey="Bg" setAllPoints="true">
                    <Color color="BLACK_FONT_COLOR" a="0.8"/>
                </Texture>
            </Layer>
            <Layer level="OVERLAY">
                <FontString parentKey="InstanceName" inherits="GameFontHighlightMedium" text="">
                    <Anchors>
                        <Anchor point="TOPLEFT" x="0" y="-10"/>
                        <Anchor point="TOPRIGHT" x="0" y="-10"/>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>
        <Scripts>
            <OnDragStart method="OnDragStart"/>
            <OnDragStop method="OnDragStop"/>
            <OnLoad method="OnLoad"/>
            <!-- <OnShow method="OnShow"/> -->
        </Scripts>
    </Frame>
</Ui>
