<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
https://raw.githubusercontent.com/Gethe/wow-ui-source/live/Interface/AddOns/Blizzard_SharedXML/UI.xsd">
    <Frame name="ICHMain" parent="UIParent" mixin="ICHMainMixin" enableMouse="true" movable="true" frameStrata="MEDIUM" registerForDrag="LeftButton">
        <Size x="800" y="600"/>
        <Anchors>
            <Anchor point="CENTER"/>
        </Anchors>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture parentKey="Bg" setAllPoints="true">
                    <Color r="0" g="0" b="0" a="0.8"/>
                </Texture>
            </Layer>
            <Layer level="OVERLAY">
                <FontString parentKey="Title" inherits="GameFontHighlightMedium" text="">
                    <Anchors>
                        <Anchor point="TOPLEFT" relativePoint="TOPLEFT" x="0" y="-10"/>
                        <Anchor point="TOPRIGHT" relativePoint="TOPRIGHT" x="0" y="-10"/>
                    </Anchors>
                    <Scripts>
                        <OnLoad function="OnTitleLoad"/> <!-- Not working -->
                    </Scripts>
                </FontString>
            </Layer>
        </Layers>
        <Frames>
            <EditBox parentKey="SearchBox" inherits="SearchBoxTemplate" autoFocus="false">
                <Size x="400" y="300"/>
                <Anchors>
                    <Anchor point="TOPRIGHT" relativeKey="Title" relativePoint="BOTTOMRIGHT" x ="-25" y="-10"/> <!-- Anchoring issue? -->
                </Anchors>
                <Scripts>
                    <OnTextChanged function="$parent:OnSearchBoxTextChanged" /> <!-- Not working -->
                </Scripts>
            </EditBox>

            <Button parentKey="CloseButton" inherits="UIPanelCloseButtonDefaultAnchors">
                <Size x="20" y="20"/>
            </Button>
        </Frames>
        <Scripts>
            <OnDragStart method="OnDragStart"/>
            <OnDragStop method="OnDragStop"/>
        </Scripts>
    </Frame>
</Ui>