<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
https://raw.githubusercontent.com/Gethe/wow-ui-source/live/Interface/AddOns/Blizzard_SharedXML/UI.xsd">
    <Frame name="ICHMain" parent="UIParent" mixin="ICHMainMixin" enableMouse="true" movable="true" frameStrata="MEDIUM" registerForDrag="LeftButton" hidden="true">
        <Size x="800" y="600"/>
        <Anchors>
            <Anchor point="CENTER"/>
        </Anchors>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture parentKey="Bg" setAllPoints="true">
                    <Color color="BLACK_FONT_COLOR" a="0.8"/>
                </Texture>
            </Layer>
            <Layer level="OVERLAY">
                <FontString parentKey="Title" inherits="GameFontHighlightMedium" text="">
                    <Anchors>
                        <Anchor point="TOPLEFT" relativePoint="TOPLEFT" x="0" y="-10"/>
                        <Anchor point="TOPRIGHT" relativePoint="TOPRIGHT" x="0" y="-10"/>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>
        <Frames>
            <EditBox parentKey="SearchBox" inherits="SearchBoxTemplate" autoFocus="false">
                <Size x="400" y="30"/>
                <Anchors>
                    <Anchor point="TOPRIGHT" relativeKey="$parent.Title" relativePoint="BOTTOMRIGHT" x ="-25" y="-10"/>
                </Anchors>
            </EditBox>

            <Button parentKey="CloseButton" inherits="UIPanelCloseButtonDefaultAnchors">
                <Size x="20" y="20"/>
            </Button>

            <Button parentKey="SearchHintsButton" inherits="ICHSquareButtonTemplate">
                <KeyValues>
                    <KeyValue key="action" type="string" value="SEARCH"></KeyValue>
                </KeyValues>
                <Anchors>
                    <Anchor point="RIGHT" relativeKey="$parent.CloseButton" relativePoint="LEFT" x="-10"/>
                </Anchors>
                <NormalTexture file="Interface\AddOns\InstanceCollectionHelper\Media\SearchHintsIcon.png"/>
                <HighlightTexture file="Interface\AddOns\InstanceCollectionHelper\Media\SearchHintsIcon.png"/>
            </Button>
            
            <Button parentKey="HelpButton" inherits="ICHSquareButtonTemplate">
                <KeyValues>
                    <KeyValue key="action" type="string" value="HELP"></KeyValue>
                </KeyValues>
                <Anchors>
                    <Anchor point="RIGHT" relativeKey="$parent.SearchHintsButton" relativePoint="LEFT" x="-10"/>
                </Anchors>
                <NormalTexture file="Interface\AddOns\InstanceCollectionHelper\Media\HelpIcon.png"/>
                <HighlightTexture file="Interface\AddOns\InstanceCollectionHelper\Media\HelpIcon.png"/>
            </Button>
            
            <Button parentKey="InfoButton" inherits="ICHSquareButtonTemplate">
                <KeyValues>
                    <KeyValue key="action" type="string" value="INFO"></KeyValue>
                </KeyValues>
                <Anchors>
                    <Anchor point="RIGHT" relativeKey="$parent.HelpButton" relativePoint="LEFT" x="-10"/>
                </Anchors>
                <NormalTexture file="Interface\AddOns\InstanceCollectionHelper\Media\InfoIcon.png"/>
                <HighlightTexture file="Interface\AddOns\InstanceCollectionHelper\Media\InfoIcon.png"/>
            </Button>

            <Frame parentKey="ListHeaders" inherits="ICHListHeadersTemplate">
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent.Title" relativePoint="BOTTOMLEFT" x="10" y="-45"/>
                    <Anchor point="TOPRIGHT" relativeKey="$parent.Title" relativePoint="BOTTOMRIGHT" x="-10" y="-45"/>
                </Anchors>
            </Frame>
            <Frame parentKey="VendorListHeaders" inherits="ICHVendorListHeadersTemplate">
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent.Title" relativePoint="BOTTOMLEFT" x="10" y="-45"/>
                    <Anchor point="TOPRIGHT" relativeKey="$parent.Title" relativePoint="BOTTOMRIGHT" x="-10" y="-45"/>
                </Anchors>
            </Frame>
            <Frame parentKey="LemixListHeaders" inherits="ICHLemixListHeadersTemplate">
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent.Title" relativePoint="BOTTOMLEFT" x="10" y="-45"/>
                    <Anchor point="TOPRIGHT" relativeKey="$parent.Title" relativePoint="BOTTOMRIGHT" x="-10" y="-45"/>
                </Anchors>
            </Frame>
        </Frames>
        <Scripts>
            <OnDragStart method="OnDragStart"/>
            <OnDragStop method="OnDragStop"/>
            <OnLoad method="OnLoad"/>
            <OnShow method="OnShow"/>
        </Scripts>
    </Frame>
</Ui>