<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
https://raw.githubusercontent.com/Gethe/wow-ui-source/live/Interface/AddOns/Blizzard_SharedXML/UI.xsd">
    <Frame name="ICHFooter" parent="ICHMain" parentKey="Footer" mixin="ICHFooterMixin">
        <Size y="35"/>
        <Anchors>
            <Anchor point="TOPLEFT" relativePoint="BOTTOMLEFT"/>
            <Anchor point="TOPRIGHT" relativePoint="BOTTOMRIGHT"/>
        </Anchors>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture parentKey="Bg" setAllPoints="true">
                    <Color r="0" g="0" b="0"/>
                </Texture>
            </Layer>
        </Layers>
        <Frames>
            <Frame parentKey="ScaleContainer">
                <Size x="200"/>
                <Anchors>
                    <Anchor point="TOPLEFT"/>
                    <Anchor point="BOTTOMLEFT"/>
                </Anchors>
                <Layers>
                    <Layer level="OVERLAY">
                        <FontString parentKey="Text" justifyH="LEFT" inherits="GameTooltipText" text="">
                            <Anchors>
                                <Anchor point="TOPLEFT" x="5" y="-5"/>
                                <Anchor point="BOTTOMLEFT" x="5" y="5"/>
                            </Anchors>
                        </FontString>
                    </Layer>
                </Layers>
                <Frames>
                    <Slider parentKey="WindowScale" inherits="MinimalSliderWithSteppersTemplate" obeyStepOnDrag="true">
                        <Anchors>
                            <Anchor point="TOPLEFT" relativeKey="$parent.Text" relativePoint="TOPRIGHT" x="5"/>
                            <Anchor point="BOTTOMRIGHT" y="5"/>
                        </Anchors>
                    </Slider>
                </Frames>
            </Frame>

            <Frame parentKey="OwnedContainer">
                <Size x="125"/>
                <Anchors>
                    <Anchor point="TOPRIGHT"/>
                    <Anchor point="BOTTOMRIGHT" x="20"/>
                </Anchors>
                <Frames>
                    <CheckButton parentKey="Checkbox" inherits="UICheckButtonTemplate" checked="false" text="">
                        <Anchors>
                            <Anchor point="TOPRIGHT"/>
                            <Anchor point="BOTTOMLEFT" relativePoint="BOTTOMRIGHT" x="-32"/>
                        </Anchors>
                    </CheckButton>
                </Frames>
            </Frame>
            
            <Frame parentKey="TomTomContainer" hidden="true">
                <Size x="175"/>
                <Anchors>
                    <Anchor point="TOPRIGHT" relativeKey="$parent.OwnedContainer" relativePoint="TOPLEFT" x="-10"/>
                    <Anchor point="BOTTOMRIGHT" relativeKey="$parent.OwnedContainer" relativePoint="BOTTOMRIGHT" x="-10"/>
                </Anchors>
                <Frames>
                    <CheckButton parentKey="Checkbox" inherits="UICheckButtonTemplate" checked="false" text="">
                        <Anchors>
                            <Anchor point="TOPRIGHT"/>
                            <Anchor point="BOTTOMLEFT" relativePoint="BOTTOMRIGHT" x="-32"/>
                        </Anchors>
                    </CheckButton>
                </Frames>
            </Frame>
        </Frames>
        <Scripts>
            <OnLoad method="OnLoad"/>
        </Scripts>
    </Frame>
</Ui>