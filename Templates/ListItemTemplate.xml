                </Layers>
            </Frame>

            <Frame parentKey="ExpansionContainer">
                <Size x="250"/>
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent.NameContainer" relativePoint="TOPRIGHT"/>
                    <Anchor point="BOTTOMLEFT" relativeKey="$parent.NameContainer" relativePoint="BOTTOMRIGHT"/>
                </Anchors>
                <Layers>
                    <Layer level="OVERLAY">
                        <FontString parentKey="Text" inherits="GameTooltipText" justifyH="LEFT" text="" wordwrap="false">
                            <Anchors>
                                <Anchor point="LEFT" relativePoint="LEFT"/>
                                <Anchor point="RIGHT" relativePoint="RIGHT"/>
                            </Anchors>
                        </FontString>
                    </Layer>
                </Layers>
            </Frame>

            <Frame parentKey="CostContainer">
                <Size x="200"/>
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent.ExpansionContainer" relativePoint="TOPRIGHT"></Anchor>
                    <Anchor point="BOTTOMLEFT" relativeKey="$parent.ExpansionContainer" relativePoint="BOTTOMRIGHT"></Anchor>
                </Anchors>
                <Frames>
                    <Button name="ICHCurrencyButton" parentKey="CurrencyButton" inherits="InsecureActionButtonTemplate">
                        <Size x="24" y="24"/>
                        <Anchors><Anchor point="LEFT" relativePoint="LEFT" x="0" y="-1" /></Anchors>
                        <Scripts>
                            <OnEnter>
                                GameTooltip:SetOwner(self, "ANCHOR_TOP")
                                GameTooltip:SetHyperlink("currency:1166")
                                GameTooltip:AddLine("\n")
                                GameTooltip:AddLine("&lt;Click to begin transfer&gt;")
                                GameTooltip:Show()
                            </OnEnter>
                            <OnLeave>GameTooltip:Hide()</OnLeave>
                        </Scripts>
                    </Button>
                </Frames>
                <Layers>
                    <Layer level="OVERLAY">
                        <FontString parentKey="Text" inherits="GameTooltipText" justifyH="LEFT" text="" wordwrap="false">
                            <Anchors>
                                <Anchor point="LEFT" relativeKey="$parent.CurrencyButton" relativePoint="RIGHT" x="5"/>
                                <Anchor point="RIGHT" relativePoint="RIGHT"/>
                            </Anchors>
                        </FontString>
                    </Layer>
                </Layers>
            </Frame>

            <Frame parentKey="OtherInfoContainer">
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent.CostContainer" relativePoint="TOPRIGHT"></Anchor>
                    <Anchor point="BOTTOMLEFT" relativeKey="$parent.CostContainer" relativePoint="BOTTOMRIGHT"></Anchor>
                    <Anchor point="RIGHT" relativePoint="RIGHT"/>
                </Anchors>
                <Frames>
                    <Frame parentKey="ICHNote" enableMouse="true">
                        <Size x="17.5" y="17.5"/>
                        <KeyValues><KeyValue key="notes" value="" type="string"/></KeyValues>
                        <Anchors><Anchor point="RIGHT" x="-25" /></Anchors>
                        <Layers>
                            <Layer level="OVERLAY">
                                <Texture parentKey="NotesIcon" file="Interface/AddOns/InstanceCollectionHelper/Media/NotesIcon.png">
                                    <Anchors>
                                        <Anchor point="TOPLEFT" relativePoint="TOPLEFT"/>
                                        <Anchor point="BOTTOMRIGHT" relativePoint="BOTTOMRIGHT"/>
                                    </Anchors>
                                </Texture>
                            </Layer>
                        </Layers>
                        <Scripts>
                            <OnEnter>
                                GameTooltip:SetOwner(self, "ANCHOR_NONE")
                                GameTooltip:SetPoint("LEFT", self, "RIGHT", 5, 0)
                                GameTooltip:AddLine(self.notes, 1, 1, 1, true)
                                GameTooltip:Show()
                            </OnEnter>
                            <OnLeave>GameTooltip:Hide()</OnLeave>
                        </Scripts>
                    </Frame>
                    <Button parentKey="ICHWaypointButton" inherits="InsecureActionButtonTemplate" hidden="true">
                        <Size x="24" y="24"/>
                        <KeyValues><KeyValue key="instanceID" value="" type="number"/></KeyValues>
                        <Anchors><Anchor point="RIGHT"/></Anchors>
                        <NormalTexture file="Interface/Minimap/Minimap-Waypoint-MapPin-Untracked"/>
                        <HighlightTexture file="Interface/Minimap/Minimap-Waypoint-MapPin-Tracked"/>
