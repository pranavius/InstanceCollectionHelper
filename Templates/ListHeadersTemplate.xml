<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
https://raw.githubusercontent.com/Gethe/wow-ui-source/live/Interface/AddOns/Blizzard_SharedXML/UI.xsd">
    <Frame name="ICHListHeadersTemplate" virtual="true" enableMouse="true" mixin="ICHListHeadersMixin">
        <Size y="25"/>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture parentKey="BorderBottom">
                    <Size y="3"/>
                    <Color color="WHITE_FONT_COLOR"/>
                    <Anchors>
                        <Anchor point="BOTTOMLEFT" relativePoint="BOTTOMLEFT"/>
                        <Anchor point="BOTTOMRIGHT" relativePoint="BOTTOMRIGHT"/>
                    </Anchors>
                </Texture>
            </Layer>
            <Layer level="OVERLAY">
                <FontString parentKey="NameHeader" inherits="GameTooltipText" justifyH="LEFT" text="Name">
                    <Size x="180"/>
                    <Anchors>
                        <Anchor point="LEFT" relativePoint="LEFT" x="29"/>
                    </Anchors>
                </FontString>
                <FontString parentKey="InstanceHeader" inherits="GameTooltipText" justifyH="LEFT" text="Instance">
                    <Size x="225"/>
                    <Anchors>
                        <Anchor point="LEFT" relativeKey="$parent.NameHeader" relativePoint="RIGHT" x="25"/>
                    </Anchors>
                </FontString>
                <FontString parentKey="DiffHeader" inherits="GameTooltipText" justifyH="LEFT" text="Available Difficulty(s)">
                    <Size x="200"/>
                    <Anchors>
                        <Anchor point="LEFT" relativeKey="$parent.InstanceHeader" relativePoint="RIGHT"/>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>
        <Scripts>
            <OnLoad method="OnLoad"/>
        </Scripts>
    </Frame>

    <Frame name="ICHVendorListHeadersTemplate" virtual="true" enableMouse="true" mixin="ICHListHeadersMixin">
        <Size y="25"/>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture parentKey="BorderBottom">
                    <Size y="3"/>
                    <Color color="WHITE_FONT_COLOR"/>
                    <Anchors>
                        <Anchor point="BOTTOMLEFT" relativePoint="BOTTOMLEFT"/>
                        <Anchor point="BOTTOMRIGHT" relativePoint="BOTTOMRIGHT"/>
                    </Anchors>
                </Texture>
            </Layer>
            <Layer level="OVERLAY">
                <FontString parentKey="NameHeader" inherits="GameTooltipText" justifyH="LEFT" text="Name">
                    <Size x="180"/>
                    <Anchors>
                        <Anchor point="LEFT" relativePoint="LEFT" x="29"/>
                    </Anchors>
                </FontString>
                <FontString parentKey="TypeHeader" inherits="GameTooltipText" justifyH="LEFT" text="Type">
                    <Size x="100"/>
                    <Anchors>
                        <Anchor point="LEFT" relativeKey="$parent.NameHeader" relativePoint="RIGHT" x="25"/>
                    </Anchors>
                </FontString>
                <FontString parentKey="ExpansionHeader" inherits="GameTooltipText" justifyH="LEFT" text="Expansion">
                    <Size x="225"/>
                    <Anchors>
                        <Anchor point="LEFT" relativeKey="$parent.TypeHeader" relativePoint="RIGHT"/>
                    </Anchors>
                </FontString>
                <FontString parentKey="CostHeader" inherits="GameTooltipText" justifyH="LEFT" text="Cost">
                    <Size x="100"/>
                    <Anchors>
                        <Anchor point="LEFT" relativeKey="$parent.ExpansionHeader" relativePoint="RIGHT"/>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>
        <Scripts>
            <OnLoad method="OnLoad"/>
        </Scripts>
    </Frame>
</Ui>