<Ui>
    <Frame name="ICHListHeadersTemplate" virtual="true" enableMouse="true">
        <Size y="25"/>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture parentKey="BorderBottom">
                    <Size y="3"/>
                    <Color r="1" g="1" b="1"/>
                    <Anchors>
                        <Anchor point="BOTTOMLEFT" relativePoint="BOTTOMLEFT"/>
                        <Anchor point="BOTTOMRIGHT" relativePoint="BOTTOMRIGHT"/>
                    </Anchors>
                </Texture>
            </Layer>
            <Layer level="OVERLAY">
                <FontString parentKey="NameHeader" inherits="GameTooltipText" justifyH="left" text="NAME">
                    <Size x="200"/>
                    <Anchors><Anchor point="LEFT" relativePoint="LEFT"/></Anchors>
                </FontString>
                <FontString parentKey="InstanceHeader" inherits="GameTooltipText" justifyH="left" text="INSTANCE">
                    <Size x="200"/>
                    <Anchors><Anchor point="LEFT" relativePoint="LEFT" x="200"/></Anchors>
                </FontString>
            </Layer>
        </Layers>
    </Frame>

    <Frame name="ICHListItemTemplate" virtual="true" enableMouse="true">
        <Size y="25"/>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture parentKey="Bg" hidden="true">
                    <Color r="1" g="1" b="1" a="0.1"/>
                    <Anchors>
                        <Anchor point="TOPLEFT" relativePoint="TOPLEFT"/>
                        <Anchor point="BOTTOMRIGHT" relativePoint="BOTTOMRIGHT"/>
                    </Anchors>
                </Texture>
            </Layer>
        </Layers>
        <Frames>
            <Frame parentKey="NameContainer">
                <Size x="200"/>
                <Anchors>
                    <Anchor point="TOPLEFT" relativePoint="TOPLEFT"/>
                    <Anchor point="BOTTOMLEFT" relativePoint="BOTTOMLEFT"/>
                </Anchors>
                <Frames>
                    <Button name="ICHViewItemButton" parentKey="ViewButton" inherits="InsecureActionButtonTemplate">
                        <Size x="23" y="23"/>
                        <Anchors><Anchor point="LEFT" relativePoint="LEFT"/></Anchors>
                        <!-- <HighlightTexture file="Interface\Buttons\ButtonHilight-Square" alphaMode="ADD"/> -->
                        <Scripts>
                            <OnEnter>
                                GameTooltip:SetOwner(self, "ANCHOR_NONE")
                                GameTooltip:SetPoint("RIGHT", self, "LEFT", -5, 0)
                                GameTooltip:AddLine("View in mount journal", 1, 1, 1, true)
                                GameTooltip:Show()
                            </OnEnter>
                            <OnLeave>
                                GameTooltip:Hide()
                            </OnLeave>
                        </Scripts>
                    </Button>
                </Frames>
                <Layers>
                    <Layer level="OVERLAY">
                        <FontString parentKey="Text" inherits="GameTooltipText" justifyH="LEFT" text="">
                            <Size x="165"/>
                            <Anchors><Anchor point="LEFT" relativeKey="$parent.ViewButton" relativePoint="RIGHT" x="5"/></Anchors>
                        </FontString>
                    </Layer>
                </Layers>
            </Frame>

            <Frame parentKey="InstanceContainer">
                <Size x="200"/>
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent.NameContainer" relativePoint="TOPRIGHT"/>
                    <Anchor point="BOTTOMLEFT" relativeKey="$parent.NameContainer" relativePoint="BOTTOMRIGHT"/>
                </Anchors>
                <Frames>
                    <Button name="ICHViewInstanceButton" parentKey="ViewButton" inherits="InsecureActionButtonTemplate">
                        <Size x="20" y="20"/>
                        <Anchors><Anchor point="LEFT" relativePoint="LEFT"/></Anchors>
                        <Scripts>
                            <OnEnter>
                                GameTooltip:SetOwner(self, "ANCHOR_NONE")
                                GameTooltip:SetPoint("RIGHT", self, "LEFT", -5, 0)
                                GameTooltip:AddLine("View in instance journal", 1, 1, 1, true)
                                GameTooltip:Show()
                            </OnEnter>
                            <OnLeave>
                                GameTooltip:Hide()
                            </OnLeave>
                        </Scripts>
                    </Button>
                </Frames>
                <Layers>
                    <Layer level="OVERLAY">
                        <FontString parentKey="Text" inherits="GameTooltipText" justifyH="LEFT" text="">
                            <Size x="175"/>
                            <Anchors><Anchor point="LEFT" relativeKey="$parent.ViewButton" relativePoint="RIGHT" x="5"/></Anchors>
                        </FontString>
                    </Layer>
                </Layers>
            </Frame>
        </Frames>
    </Frame>
</Ui>