<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
https://raw.githubusercontent.com/Gethe/wow-ui-source/live/Interface/AddOns/Blizzard_SharedXML/UI.xsd">
    <Frame name="ICHListHeadersTemplate" virtual="true" enableMouse="true">
        <Size y="25"/>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture parentKey="BorderBottom">
                    <Size y="3"/>
                    <Color r="1" g="1" b="1"/>
                    <Anchors>
                        <Anchor point="BOTTOMLEFT" relativePoint="BOTTOMLEFT"/>
                        <Anchor point="BOTTOMRIGHT" relativePoint="BOTTOMRIGHT"/>
                    </Anchors>
                </Texture>
            </Layer>
            <Layer level="OVERLAY">
                <FontString parentKey="NameHeader" inherits="GameTooltipText" justifyH="LEFT" text="Name">
                    <Size x="180"/>
                    <Anchors><Anchor point="LEFT" relativePoint="LEFT" x="29"/></Anchors>
                </FontString>
                <FontString parentKey="InstanceHeader" inherits="GameTooltipText" justifyH="LEFT" text="Instance">
                    <Size x="225"/>
                    <Anchors><Anchor point="LEFT" relativeKey="$parent.NameHeader" relativePoint="RIGHT" x="25"/></Anchors>
                </FontString>
                <FontString parentKey="DiffHeader" inherits="GameTooltipText" justifyH="LEFT" text="Available Difficulty(s)">
                    <Size x="250"/>
                    <Anchors><Anchor point="LEFT" relativeKey="$parent.InstanceHeader" relativePoint="RIGHT"/></Anchors>
                </FontString>
                <FontString parentKey="NotesHeader" inherits="GameTooltipText" justifyH="LEFT" text="Notes">
                    <Anchors>
                        <Anchor point="LEFT" relativeKey="$parent.DiffHeader" relativePoint="RIGHT"/>
                        <Anchor point="RIGHT" relativePoint="RIGHT"/>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>
    </Frame>

    <Button name="ICHGenericButtonTemplate" virtual="true" inherits="InsecureActionButtonTemplate">
        <KeyValues>
            <KeyValue key="action" value="" type="string" />
        </KeyValues>
        <Size x="20" y="20"/>
        <Scripts>
            <OnEnter>
                if self.action == "INFO" then
                    GameTooltip:SetOwner(self, "ANCHOR_TOP")
                    GameTooltip:SetText(ICH_LANG["How To Use:"])
                    GameTooltip:AddLine("\n")
                    GameTooltip:AddLine("- "..ICH_LANG["Find the mount you want to collect in the list and click the button for the difficulty you want to run on")
                    GameTooltip:AddLine(ICH_LANG["to make sure it is updated."])
                    GameTooltip:AddLine("- "..ICH_LANG["When you are locked out for a mount on a particular difficulty, the button for that difficulty will be disabled."])
                    GameTooltip:AddLine("- "..ICH_LANG["A button will also be disabled for legacy raids completed on another difficulty since those lockouts"])
                    GameTooltip:AddLine(ICH_LANG["are shared across difficulties."])
                elseif self.action == "SEARCH" then
                    GameTooltip:SetOwner(self:GetParent(), "ANCHOR_NONE")
                    GameTooltip:SetPoint("TOPLEFT", self:GetParent(), "TOPRIGHT")
                    GameTooltip:SetText(ICH_LANG["Search Hints:"])
                    GameTooltip:AddLine("\n")
                    GameTooltip:AddLine("- "..ICH_LANG["\"raid\" will show all mounts that can be collected from a raid"])
                    GameTooltip:AddLine("- "..ICH_LANG["\"10\" will show all mounts that can be collected from a legacy 10 player raid (Normal or Heroic)"])
                    GameTooltip:AddLine("- "..ICH_LANG["\"fel\" will show all mounts and instances that contain \"fel\" in the name"])
                    GameTooltip:AddLine("- "..ICH_LANG["\"mythic\" will show all mounts that can be obtained from a Mythic dungeon or raid"])
                    GameTooltip:AddLine("- "..ICH_LANG["\"lfr\" will show all mounts that can be obtained from Raid Finder (LFR) difficulty raids"])
                end
                GameTooltip:Show()
            </OnEnter>
            <OnLeave>
                GameTooltip:Hide()
            </OnLeave>
        </Scripts>
    </Button>

    <Button name="ICHDifficultyButtonTemplate" virtual="true" inherits="UIPanelButtonTemplate">
        <Size x="50"/>
        <Layers>
            <Layer level="OVERLAY">
                <Texture parentKey="ButtonTint" file="Interface/Buttons/WHITE8x8" alphaMode="ALPHAKEY">
                    <Anchors>
                        <Anchor point="TOPLEFT" relativeKey="$parent.Left" relativePoint="TOPLEFT"/>
                        <Anchor point="BOTTOMRIGHT" relativeKey="$parent.Right" relativePoint="BOTTOMRIGHT"/>
                    </Anchors>
                    <TexCoords left="0" right="0" top="1" bottom="1"/>
                </Texture>
            </Layer>
        </Layers>
        <Scripts>
            <OnEnter>
                GameTooltip:SetOwner(self, "ANCHOR_TOP")
                GameTooltip:SetText(ICH:GetInstanceDifficultyText(self.difficultyID))
                if self.sharedDifficulties then
                    GameTooltip:AddLine("\n")
                    GameTooltip:AddLine(ICH_LANG["Shares lockout with:"], 1, 1, 1)
                    for shared, _ in pairs(self.sharedDifficulties) do
                        GameTooltip:AddLine("- "..ICH:GetInstanceDifficultyText(shared))
                    end
                end
                GameTooltip:Show()
            </OnEnter>
            <OnLeave>GameTooltip:Hide()</OnLeave>
        </Scripts>
    </Button>

    <Frame name="ICHListItemTemplate" virtual="true" enableMouse="true">
        <Size y="25"/>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture parentKey="Bg" hidden="true">
                    <Color r="1" g="1" b="1" a="0.1"/>
                    <Anchors>
                        <Anchor point="TOPLEFT" relativePoint="TOPLEFT"/>
                        <Anchor point="BOTTOMRIGHT" relativePoint="BOTTOMRIGHT"/>
                    </Anchors>
                </Texture>
                <Texture parentKey="OwnedBg" hidden="true">
                    <Color r="0.082" g="0.702" b="0" a="0.5"/>
                    <Anchors>
                        <Anchor point="TOPLEFT" relativePoint="TOPLEFT"/>
                        <Anchor point="BOTTOMRIGHT" relativePoint="BOTTOMRIGHT"/>
                    </Anchors>
                </Texture>
            </Layer>
        </Layers>
        <Frames>
            <Frame parentKey="NameContainer">
                <Size x="209"/>
                <Anchors>
                    <Anchor point="TOPLEFT" relativePoint="TOPLEFT"/>
                    <Anchor point="BOTTOMLEFT" relativePoint="BOTTOMLEFT"/>
                </Anchors>
                <Frames>
                    <Button name="ICHViewItemButton" parentKey="ViewButton" inherits="InsecureActionButtonTemplate">
                        <Size x="24" y="24"/>
                        <Anchors><Anchor point="LEFT" relativePoint="LEFT"/></Anchors>
                        <Scripts>
                            <OnEnter>
                                GameTooltip:SetOwner(self, "ANCHOR_NONE")
                                GameTooltip:SetPoint("RIGHT", self, "LEFT", -5, 0)
                                GameTooltip:AddLine(ICH_LANG["View in mount journal"], 1, 1, 1, true)
                                GameTooltip:Show()
                            </OnEnter>
                            <OnLeave>GameTooltip:Hide()</OnLeave>
                        </Scripts>
                    </Button>
                </Frames>
                <Layers>
                    <Layer level="OVERLAY">
                        <FontString parentKey="Text" inherits="GameTooltipText" justifyH="LEFT" text="">
                            <Anchors><Anchor point="LEFT" relativeKey="$parent.ViewButton" relativePoint="RIGHT" x="5"/></Anchors>
                        </FontString>
                    </Layer>
                </Layers>
            </Frame>

            <Frame parentKey="InstanceContainer">
                <Size x="250"/>
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent.NameContainer" relativePoint="TOPRIGHT"/>
                    <Anchor point="BOTTOMLEFT" relativeKey="$parent.NameContainer" relativePoint="BOTTOMRIGHT"/>
                </Anchors>
                <Frames>
                    <Button name="ICHViewInstanceButton" parentKey="ViewButton" inherits="InsecureActionButtonTemplate">
                        <Size x="20" y="20"/>
                        <Anchors><Anchor point="LEFT" relativePoint="LEFT"/></Anchors>
                        <Scripts>
                            <OnEnter>
                                GameTooltip:SetOwner(self, "ANCHOR_NONE")
                                GameTooltip:SetPoint("RIGHT", self, "LEFT", -5, 0)
                                GameTooltip:AddLine(ICH_LANG["View in encounter journal"], 1, 1, 1, true)
                                GameTooltip:Show()
                            </OnEnter>
                            <OnLeave>GameTooltip:Hide()</OnLeave>
                        </Scripts>
                    </Button>
                </Frames>
                <Layers>
                    <Layer level="OVERLAY">
                        <FontString parentKey="Text" inherits="GameTooltipText" justifyH="LEFT" text="">
                            <Anchors><Anchor point="LEFT" relativeKey="$parent.ViewButton" relativePoint="RIGHT" x="5"/></Anchors>
                        </FontString>
                    </Layer>
                </Layers>
            </Frame>

            <Frame parentKey="DifficultyContainer">
                <Size x="250"/>
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent.InstanceContainer" relativePoint="TOPRIGHT"></Anchor>
                    <Anchor point="BOTTOMLEFT" relativeKey="$parent.InstanceContainer" relativePoint="BOTTOMRIGHT"></Anchor>
                </Anchors>
                <Frames>
                    <Button parentKey="RaidDiffLFRButton" inherits="ICHDifficultyButtonTemplate" hidden="true">
                        <KeyValues><KeyValue key="difficultyID" value="17" type="number"/></KeyValues>
                        <Scripts>
                            <OnClick>
                                ICH:PrintChatMessage(WrapTextInColor(ICH_LANG["This button is only intended for tracking a Raid Finder (LFR) lockout. Raid difficulty has not been changed."], DARKYELLOW_FONT_COLOR))
                            </OnClick>
                        </Scripts>
                    </Button>
                    <Button parentKey="RaidDiffNormalButton" inherits="ICHDifficultyButtonTemplate" hidden="true">
                        <KeyValues><KeyValue key="difficultyID" value="14" type="number"/></KeyValues>
                        <Scripts><OnClick>ICH:SetInstanceDifficulty(self.difficultyID)</OnClick></Scripts>
                    </Button>
                    <Button parentKey="RaidDiffHeroicButton" inherits="ICHDifficultyButtonTemplate" hidden="true">
                        <KeyValues><KeyValue key="difficultyID" value="15" type="number"/></KeyValues>
                        <Scripts><OnClick>ICH:SetInstanceDifficulty(self.difficultyID)</OnClick></Scripts>
                    </Button>
                    <Button parentKey="RaidDiffMythicButton" inherits="ICHDifficultyButtonTemplate" hidden="true">
                        <KeyValues><KeyValue key="difficultyID" value="16" type="number"/></KeyValues>
                        <Scripts><OnClick>ICH:SetInstanceDifficulty(self.difficultyID)</OnClick></Scripts>
                    </Button>
                    <Button parentKey="RaidDiff10Button" inherits="ICHDifficultyButtonTemplate" hidden="true">
                        <KeyValues><KeyValue key="difficultyID" value="3" type="number"/></KeyValues>
                        <Scripts><OnClick>ICH:SetInstanceDifficulty(self.difficultyID)</OnClick></Scripts>
                    </Button>
                    <Button parentKey="RaidDiff25Button" inherits="ICHDifficultyButtonTemplate" hidden="true">
                        <KeyValues><KeyValue key="difficultyID" value="4" type="number"/></KeyValues>
                        <Scripts><OnClick>ICH:SetInstanceDifficulty(self.difficultyID)</OnClick></Scripts>
                    </Button>
                    <Button parentKey="RaidDiff10HeroicButton" inherits="ICHDifficultyButtonTemplate" hidden="true">
                        <KeyValues><KeyValue key="difficultyID" value="5" type="number"/></KeyValues>
                        <Scripts><OnClick>ICH:SetInstanceDifficulty(self.difficultyID)</OnClick></Scripts>
                    </Button>
                    <Button parentKey="RaidDiff25HeroicButton" inherits="ICHDifficultyButtonTemplate" hidden="true">
                        <KeyValues><KeyValue key="difficultyID" value="6" type="number"/></KeyValues>
                        <Scripts><OnClick>ICH:SetInstanceDifficulty(self.difficultyID)</OnClick></Scripts>
                    </Button>
                    <Button parentKey="DungDiffNormalButton" inherits="ICHDifficultyButtonTemplate" hidden="true">
                        <KeyValues><KeyValue key="difficultyID" value="1" type="number"/></KeyValues>
                        <Scripts><OnClick>ICH:SetInstanceDifficulty(self.difficultyID)</OnClick></Scripts>
                    </Button>
                    <Button parentKey="DungDiffHeroicButton" inherits="ICHDifficultyButtonTemplate" hidden="true">
                        <KeyValues><KeyValue key="difficultyID" value="2" type="number"/></KeyValues>
                        <Scripts><OnClick>ICH:SetInstanceDifficulty(self.difficultyID)</OnClick></Scripts>
                    </Button>
                    <Button parentKey="DungDiffMythicButton" inherits="ICHDifficultyButtonTemplate" hidden="true">
                        <KeyValues><KeyValue key="difficultyID" value="23" type="number"/></KeyValues>
                        <Scripts><OnClick>ICH:SetInstanceDifficulty(self.difficultyID)</OnClick></Scripts>
                    </Button>
                </Frames>
            </Frame>

            <Frame parentKey="NotesContainer" hidden="true">
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent.DifficultyContainer" relativePoint="TOPRIGHT"></Anchor>
                    <Anchor point="BOTTOMLEFT" relativeKey="$parent.DifficultyContainer" relativePoint="BOTTOMRIGHT"></Anchor>
                    <Anchor point="RIGHT" relativePoint="RIGHT"/>
                </Anchors>
                <Frames>
                    <Frame parentKey="ICHNote" enableMouse="true">
                        <Size x="20" y="20"/>
                        <KeyValues><KeyValue key="Notes" value="" type="string"/></KeyValues>
                        <Anchors><Anchor point="LEFT" relativePoint="LEFT"/></Anchors>
                        <Layers>
                            <Layer level="OVERLAY">
                                <Texture parentKey="NotesIcon" file="interface/icons/inv_misc_note_04">
                                    <Anchors>
                                        <Anchor point="TOPLEFT" relativePoint="TOPLEFT"/>
                                        <Anchor point="BOTTOMRIGHT" relativePoint="BOTTOMRIGHT"/>
                                    </Anchors>
                                </Texture>
                            </Layer>
                        </Layers>
                        <Scripts>
                            <OnEnter>
                                GameTooltip:SetOwner(self, "ANCHOR_NONE")
                                GameTooltip:SetPoint("LEFT", self, "RIGHT", 5, 0)
                                GameTooltip:AddLine(self.Notes, 1, 1, 1, true)
                                GameTooltip:Show()
                            </OnEnter>
                            <OnLeave>GameTooltip:Hide()</OnLeave>
                        </Scripts>
                    </Frame>
                </Frames>
            </Frame>
        </Frames>
    </Frame>

    <!-- Unused for right now -->
    <Frame name="ICHFooterTemplate" virtual="true">
        <Size y="25"/>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture parentKey="Bg" setAllPoints="true">
                    <Color r="0" g="0" b="0" a="1"/>
                </Texture>
            </Layer>
        </Layers>
        <Frames>
            <Frame parentKey="ScaleContainer">
                <Size x="200"/>
                <Anchors>
                    <Anchor point="TOPLEFT" relativePoint="TOPLEFT"/>
                    <Anchor point="BOTTOMLEFT" relativePoint="BOTTOMLEFT"/>
                </Anchors>
                <Layers>
                    <Layer level="OVERLAY">
                        <FontString parentKey="Title" inherits="GameTooltipText" justifyH="LEFT" text="Scale">
                            <Anchors>
                                <Anchor point="LEFT" relativePoint="LEFT" x="5"/>
                            </Anchors>
                        </FontString>
                    </Layer>
                </Layers>
                <Frames>
                    <Slider parentKey="WindowScale" inherits="MinimalSliderWithSteppersTemplate"/>
                </Frames>
            </Frame>
        </Frames>
    </Frame>
</Ui>